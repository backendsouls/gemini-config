# Gemini CLI Sandbox Configuration
# Usage: copy to .env and 'source .env' or use a tool that loads .env files

# Set the sandbox provider to docker
export GEMINI_SANDBOX=docker

# Set the default image to use for 'gemini -s'
export GEMINI_SANDBOX_IMAGE=gemini-sandbox-all

# Set a dedicated workspace directory to share with the sandbox
# export WORKSPACE=/path/to/your/projects

# Optional: Additional mounts
# export SANDBOX_MOUNTS="/host/path:/container/path:ro"
